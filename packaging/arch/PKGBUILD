# Maintainer: EnglishMoribund
# Repackages the .deb from the GitHub release (same binary the deb/rpm ship).
pkgname=morenglish-sentence-miner-bin
pkgver=0.3.2
pkgrel=1
pkgdesc="MorEnglish Sentence Miner — mine English sentences, tag their grammar, forge diagrams"
arch=('x86_64')
url="https://github.com/EnglishMoribund/MorEnglish_Sentence_Miner"
license=('custom:none')
depends=('webkit2gtk-4.1' 'gtk3')
provides=('morenglish-sentence-miner')
conflicts=('morenglish-sentence-miner')
source=("$url/releases/download/v$pkgver/morenglish-sentence-miner_${pkgver}_amd64.deb")
sha256sums=('ed224c88855def832430ba76cc7780717df0155926602e143e0e153dd550ab69')

package() {
  # makepkg has already unpacked the .deb (ar archive) into $srcdir
  bsdtar -xf "$srcdir/data.tar.gz" -C "$pkgdir"
}
