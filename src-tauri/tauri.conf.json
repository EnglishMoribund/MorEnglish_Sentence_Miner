{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "morenglish-sentence-miner",
  "version": "0.1.0",
  "identifier": "com.sentence.miner",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MorEnglish Sentence Miner",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
